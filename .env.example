# 火山引擎（Volcengine）OpenAI 兼容网关地址
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 火山引擎 API Key（请替换为你的真实密钥）
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# 模型名：按当前 MVP 固定为 UI 视觉推理模型
VOLCENGINE_MODEL=doubao-1-5-thinking-vision-pro-250428

# 任务阶段（默认 find_lark，仅找并激活飞书）
# 可选：find_lark | full_flow
TASK_STAGE=find_lark

# Agent 最大循环轮数（可选）
# find_lark 阶段建议 2~3；full_flow 可设 8~15
MAX_LOOP_COUNT=10

# 日志详细模式（可选）
# 0: 精简日志（默认，过滤截图/base64）| 1: 完整日志
LOG_VERBOSE=0

# full_flow 阶段可配置的联系人和发送消息
TARGET_CONTACT=张三
MESSAGE_TEXT=hello world
